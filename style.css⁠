body {
    margin: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #1a1a1a;
    color: #ffffff;
}

.screen {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

.hidden {
    display: none !important;
}

/* Écran de blocage */
#auth-gate {
    justify-content: center;
    align-items: center;
    background: radial-gradient(circle, #2c2f33 0%, #111 100%);
}

.auth-box {
    text-align: center;
    background: #23272a;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    max-width: 90%;
}

.btn-discord {
    background-color: #5865F2;
    color: white;
    border: none;
    padding: 12px 24px;
    font-size: 16px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.3s;
}
.btn-discord:hover { background-color: #4752c4; }

/* Boutique */
header {
    background-color: #111;
    padding: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #ff4500;
}

.cart-icon {
    font-size: 24px;
    cursor: pointer;
    position: relative;
}

#cart-count {
    background: #ff4500;
    color: white;
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 50%;
    position: absolute;
    top: -5px;
    right: -10px;
}

.products-grid {
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.product-card {
    background: #23272a;
    border-radius: 8px;
    padding: 15px;
    text-align: center;
    border: 1px solid #333;
}

.product-img {
    font-size: 50px;
    margin-bottom: 10px;
}

.price {
    color: #ff4500;
    font-weight: bold;
    font-size: 18px;
}

.btn-add {
    background: #ff4500;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 50px;
    cursor: pointer;
    width: 100%;
}

/* Panier Flottant */
.cart-sidebar {
    position: fixed;
    right: 0;
    top: 0;
    width: 300px;
    height: 100vh;
    background: #111;
    box-shadow: -5px 0 15px rgba(0,0,0,0.5);
    padding: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}

.cart-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #333;
}

.cart-total {
    margin-top: auto;
    font-size: 20px;
    font-weight: bold;
    padding: 20px 0;
    border-top: 2px solid #ff4500;
}

.btn-checkout {
    background: #25D366; /* Vert WhatsApp */
    color: white;
    border: none;
    padding: 15px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
}
